{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Rosetta",
  "version": "0.1.0",
  "identifier": "com.rosetta.desktop",
  "build": {
    "beforeDevCommand": "bun --filter=@rosetta/app dev",
    "beforeBuildCommand": "bun --filter=@rosetta/app build",
    "devUrl": "http://localhost:5173",
    "frontendDist": "../../app/dist"
  },
  "app": {
    "windows": [
      {
        "title": "Rosetta",
        "width": 1200,
        "height": 800,
        "resizable": true,
        "fullscreen": false
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": ["nsis"],
    "publisher": "Rosetta",
    "copyright": "Copyright © 2025 Rosetta",
    "category": "DeveloperTool",
    "shortDescription": "本地 LLM API 格式转换中枢",
    "longDescription": "Rosetta 是本机运行的 LLM API 代理 + 翻译器:任一请求格式(Messages / Chat Completions / Responses)可转到任意上游,内置 mock 上游允许开箱即用。",
    "externalBin": ["binaries/rosetta-server"],
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "windows": {
      "nsis": {
        "installerIcon": "icons/icon.ico",
        "installMode": "currentUser",
        "languages": ["English", "SimpChinese"]
      }
    }
  },
  "plugins": {
    "updater": {
      "endpoints": [
        "https://github.com/cliffordll/rosetta/releases/latest/download/latest.json"
      ],
      "pubkey": "REPLACE_WITH_BASE64_PUBKEY_FROM_tauri_signer_generate"
    }
  }
}
